# Server (never expose in browser)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# HMAC for admin httpOnly session (separate from Stripe)
ADMIN_AUTH_SECRET=

# Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe price IDs (subscription checkout `plan`: essential | professional | enterprise)
STRIPE_ESSENTIAL_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
# Legacy aliases (still read if new names unset)
STRIPE_STARTER_PRICE_ID=
STRIPE_CORE_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
STRIPE_RETAIL_PRICE_ID=

# Phase F — optional: forward /api/parse/* to existing Flask (same paths). Else use OPENAI_API_KEY below.
# INTERNAL_ENGINE_BASE_URL=http://localhost:5000
# INTERNAL_ENGINE_SECRET=

# Phase F — denial parse + appeal preview/PDF (server only; never expose to browser)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Phase H — Stripe: configure Dashboard webhook to POST {NEXT_PUBLIC_SITE_URL}/api/webhooks/stripe (or keep Netlify function; same secret).
