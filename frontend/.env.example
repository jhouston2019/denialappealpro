# Supabase (required for login / register in the CRA shell)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Next.js API origin when the CRA app is served separately (pricing + checkout + plans JSON)
# Example local: http://localhost:3000
REACT_APP_NEXT_API_URL=http://localhost:3000

# Optional: legacy Flask engine (extract/generate) if still used
# REACT_APP_API_URL=http://localhost:5000
